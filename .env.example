# ============================================================
# 课标到课堂｜AI 教学设计工作台 — 环境变量示例
# 复制本文件为 .env 并按需修改。默认即开箱可演示（mock 模式）。
# 所有 API Key 仅由后端读取，前端永远不会接触到。
# ============================================================

# 选择 AI 提供方：mock | openai | anthropic | dify
API_PROVIDER=mock

# 总开关：true 时强制使用 mock 数据，即使配了真实 Key 也不会调用
MOCK_MODE=true

# 后端端口（前端开发时通过 Vite 代理转发到这里）
PORT=3001

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ---- Dify ----
DIFY_API_KEY=
DIFY_API_BASE=https://api.dify.ai/v1
