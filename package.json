{
  "name": "curriculum-to-classroom-workbench",
  "version": "1.0.0",
  "private": true,
  "description": "课标到课堂｜AI 教学设计工作台 — 流程化教学设计工作台（React + Vite + TS 前端 / Node + Express 后端）",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "setup": "node scripts/install-deps.js",
    "postinstall": "node scripts/install-deps.js",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
